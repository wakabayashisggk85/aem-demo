<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        pageTitle="Hero Component Demo"
        jcr:primaryType="cq:PageContent"
        jcr:title="Hero Demo"
        cq:template="/conf/mysite/settings/wcm/templates/page-content"
        sling:resourceType="mysite/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="mysite/components/container"
            layout="responsiveGrid">
            <container
                jcr:primaryType="nt:unstructured"
                sling:resourceType="mysite/components/container">
                <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="mysite/components/container"
                    layout="responsiveGrid">
                    <hero
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="mysite/components/hero"
                        alignment="left"
                        alt="Financial success and growth"
                        minHeight="600"
                        fileReference="/content/dam/core-components/AdobeStock_175749320_surfing.jpg"
                        overlayOpacity="0.5">
                        <title
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="mysite/components/title"
                            jcr:title="Transform Your Financial Future"
                            type="h1"/>
                        <text
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="mysite/components/text"
                            text="&lt;p&gt;Discover innovative banking solutions designed to help you achieve your goals. From personal accounts to business services, we're here to support your journey.&lt;/p&gt;"
                            textIsRich="true"/>
                        <button_primary
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="mysite/components/button"
                            jcr:title="Get Started"
                            link="/content/mysite/us/en"/>
                        <button_secondary
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="mysite/components/button"
                            jcr:title="Learn More"
                            link="/content/mysite/us/en"/>
                    </hero>
                    <title
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="mysite/components/title"
                        jcr:title="Our Services"
                        type="h2"/>
                    <text
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="mysite/components/text"
                        text="&lt;p&gt;This is a demo page showcasing the hero component.&lt;/p&gt; &lt;p&gt;The hero section above demonstrates a full-width background image with content overlay, alignment options, and call-to-action buttons.&lt;/p&gt;"
                        textIsRich="true"/>
                </container>

            </container>
        </root>
    </jcr:content>
</jcr:root>
